    "constants": {
      "actuator_excerpts": [
        "GO2_ACTUATOR_HIP = BuiltinPositionActuatorCfg(\n  target_names_expr=(\n    \".*hip_.*\",\n  ),\n  stiffness=20.0,\n  damping=1.0,\n  effort_limit=23.5,\n  armature=0.01,\n)",
